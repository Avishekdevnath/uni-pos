NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Public URL of this backend (used in receipt links, logs, etc.)
BACKEND_URL=https://api.yourdomain.com

DATABASE_URL=postgres://postgres:postgres@localhost:5432/uni_pos
DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/uni_pos

ADMIN_ALLOWED_ORIGINS=https://admin.yourdomain.com
# Add "null" to allow the packaged Electron POS app (file:// origin)
CORS_ORIGINS=https://admin.yourdomain.com,null

# Auth — generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Platform admin JWT — separate secret for platform superadmin routes
# generate with: openssl rand -base64 64
PLATFORM_JWT_SECRET=replace-with-a-different-long-random-secret

# Seed script defaults (not used at runtime)
ADMIN_FULL_NAME=Owner Admin
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=your-secure-password-here
ADMIN_ORGANIZATION_NAME=Demo Organization
ADMIN_TENANT_NAME=Demo Tenant
ADMIN_TENANT_SLUG=demo-tenant
ADMIN_BRANCH_NAME=Main Branch
ADMIN_BRANCH_CODE=MAIN

# Cloudinary — product image uploads (get from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
